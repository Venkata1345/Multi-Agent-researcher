# --- Model provider (Phase 2) ---
# Default provider is OpenAI. Swapping to Anthropic is a one-line change in config.py.
OPENAI_API_KEY=sk-...
# Default model used by all agents unless overridden. Cheap for iteration.
RESEARCH_MODEL=gpt-4o-mini

# --- Observability (Phase 2) ---
# When enabled, every agent / tool / LLM call is traced to LangSmith.
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=ls-...
LANGSMITH_PROJECT=multi-agent-research
LANGSMITH_ENDPOINT=https://api.smith.langchain.com

# --- Web search MCP server (Phase 3) ---
# Backend: Tavily (purpose-built for LLM agents; clean structured snippets).
TAVILY_API_KEY=tvly-...

# --- Filesystem MCP server (Phase 3) ---
# The filesystem tool is sandboxed to this directory. Keep it inside the repo.
RESEARCH_WORKSPACE=./workspace
